# RemoteControl - Root Environment Configuration
# Domain & Network
RC_DOMAIN=local.remotecontrol.rs
RC_SCHEME=https

# Ports
RC_NGINX_PORT=443
RC_API_PORT=7481
RC_SOCKET_PORT=7482
RC_POSTGRES_PORT=7483
RC_PGBOUNCER_PORT=7484
RC_PGADMIN_PORT=7485
RC_POSTFIX_PORT=7486

# PostgreSQL
POSTGRES_DB=remotecontrol
POSTGRES_USER=rcadmin
POSTGRES_PASSWORD=rc_secret_change_me_in_production

# PgBouncer
PGBOUNCER_MAX_CLIENT_CONN=200
PGBOUNCER_DEFAULT_POOL_SIZE=20

# PgAdmin
PGADMIN_DEFAULT_EMAIL=admin@remotecontrol.rs
PGADMIN_DEFAULT_PASSWORD=pgadmin_secret_change_me

# JWT
JWT_SECRET=jwt_secret_change_me_in_production_use_64_chars_minimum_here_ok
JWT_EXPIRY_SECONDS=86400

# SMTP (Mailtrap)
MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=7b399a1dbd258e
MAIL_PASSWORD=c28c49db891124
MAIL_FROM_EMAIL=noreply@remotecontrol.rs
MAIL_FROM_NAME=RemoteControl

# DTLS
DTLS_CERT_PATH=/etc/ssl/certs/dtls-cert.pem
DTLS_KEY_PATH=/etc/ssl/private/dtls-key.pem
